# Lightweight Dockerfile for Railway deployment (CPU-only)
# Uses the official Ollama image as base
FROM ollama/ollama:latest

# Expose Ollama API port
EXPOSE 11434

# Railway injects PORT env var; Ollama reads OLLAMA_HOST
ENV OLLAMA_HOST=0.0.0.0:11434

# Note: mount /root/.ollama as a Railway Volume for model persistence
ENTRYPOINT ["/bin/ollama"]
CMD ["serve"]
